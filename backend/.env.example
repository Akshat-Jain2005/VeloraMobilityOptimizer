# ─────────────────────────────────────────────────
# Velora Backend — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# Python binary path (default: python3)
# If you use a virtualenv, set the full path e.g. /home/anay/venv/bin/python
PYTHON_BIN=python3

# Maps API key — leave blank to use Haversine (no API needed)
# Get a free key from: https://openrouteservice.org/dev/#/signup
# Or use Google Maps key (starts with AIza...)
MAPS_API_KEY=
